<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FileViewer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FileViewer.Views"
    Shell.FlyoutBehavior="Disabled"  
    Title="">

    <TabBar>
        <Tab Title="Home">
            <Tab.Icon>
                <FontImageSource FontFamily="FASolid" Glyph="{StaticResource home}"  />
            </Tab.Icon>
            <ShellContent Title="Home" ContentTemplate="{DataTemplate local:MainPage}"  Route="MainPage" />           
        </Tab> 
        <Tab Title="Setting">
            <Tab.Icon>
                <FontImageSource FontFamily="FASolid" Glyph="{StaticResource setting}"  />
            </Tab.Icon>
            <ShellContent  Title="Setting" ContentTemplate="{DataTemplate local:Setting }" Route="Setting" />
        </Tab>
    </TabBar>  
</Shell>
